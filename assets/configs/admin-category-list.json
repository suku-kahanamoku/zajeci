{
  "syscode": "admin-category-list",
  "restUrl": "/api/admin/category",
  "deleteUrl": "/api/admin/category/${item.id}",
  "factory": {
    "url": "${name}--$${id}"
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.category.name"
    },
    {
      "name": "syscode",
      "type": "text",
      "label": "$.category.syscode"
    },
    {
      "name": "position",
      "type": "number",
      "label": "$.category.position"
    }
  ]
}