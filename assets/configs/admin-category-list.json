{
  "syscode": "admin-category-list",
  "restUrl": "/api/admin/category",
  "deleteUrl": "/api/admin/category/${item.id}",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "id",
    "name",
    "syscode",
    "parent_id",
    "is_active"
  ],
  "fields": [
    {
      "name": "id",
      "label": "$.category.id"
    },
    {
      "name": "name",
      "label": "$.category.name"
    },
    {
      "name": "syscode",
      "label": "$.category.syscode"
    },
    {
      "name": "parent_id",
      "label": "$.category.parent_id"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.is_active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}