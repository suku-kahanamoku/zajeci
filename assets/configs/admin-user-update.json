{
  "syscode": "admin-user-update",
  "restUrl": "/api/admin/user/${route.meta.id}",
  "patchUrl": "/api/admin/user/${route.meta.id}",
  "method": "PATCH",
  "fields": [
    {
      "name": "email",
      "type": "email",
      "label": "$.user.email",
      "placeholder": "$.user.placeholder.email",
      "required": true
    },
    {
      "name": "first_name",
      "type": "text",
      "label": "$.user.name",
      "placeholder": "$.user.placeholder.name"
    },
    {
      "name": "last_name",
      "type": "text",
      "label": "$.user.surname",
      "placeholder": "$.user.placeholder.surname"
    },
    {
      "name": "phone",
      "type": "text",
      "label": "$.user.phone",
      "placeholder": "$.user.placeholder.phone"
    },
    {
      "name": "role",
      "type": "select",
      "label": "$.user.role",
      "options": [
        {
          "label": "$.form.admin",
          "value": "admin"
        },
        {
          "label": "$.form.user",
          "value": "user"
        },
        {
          "label": "$.form.guest",
          "value": "guest"
        }
      ]
    }
  ]
}