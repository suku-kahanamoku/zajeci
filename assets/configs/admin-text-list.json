{
  "syscode": "admin-text-list",
  "restUrl": "/api/admin/text",
  "deleteUrl": "/api/admin/text/${item.id}",
  "factory": {
    "url": "${syscode}--$${id}"
  },
  "projection": [
    "id",
    "syscode",
    "title",
    "language",
    "is_active"
  ],
  "fields": [
    {
      "name": "id",
      "label": "$.text.id"
    },
    {
      "name": "syscode",
      "label": "$.text.syscode"
    },
    {
      "name": "title",
      "label": "$.text.title"
    },
    {
      "name": "language",
      "label": "$.text.language"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.is_active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}