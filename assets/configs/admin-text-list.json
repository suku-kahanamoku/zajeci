{
  "syscode": "admin-text-list",
  "restUrl": "/api/admin/text",
  "deleteUrl": "/api/admin/text/${item.id}",
  "pagination": {
    "limit": 20
  },
  "factory": {
    "url": "${syscode}--$${id}"
  },
  "fields": [
    {
      "name": "syscode",
      "label": "$.text.syscode",
      "operator": {
        "value": "$regex",
        "enabled": true
      }
    },
    {
      "name": "title",
      "label": "$.text.title",
      "operator": {
        "value": "$regex",
        "enabled": true
      }
    },
    {
      "name": "language",
      "label": "$.text.language",
      "operator": {
        "value": "$regex",
        "enabled": true
      }
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.is_active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}