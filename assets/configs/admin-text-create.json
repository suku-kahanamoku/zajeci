{
  "syscode": "admin-text-create",
  "postUrl": "/api/admin/text",
  "method": "POST",
  "fields": [
    {
      "name": "syscode",
      "type": "text",
      "label": "$.text.syscode",
      "placeholder": "$.text.placeholder.syscode",
      "required": true
    },
    {
      "name": "title",
      "type": "text",
      "label": "$.text.title",
      "placeholder": "$.text.placeholder.title"
    },
    {
      "name": "content",
      "type": "textarea",
      "label": "$.text.content",
      "placeholder": "$.text.placeholder.content"
    },
    {
      "name": "language",
      "type": "select",
      "label": "$.text.language",
      "options": [
        { "label": "Čeština", "value": "cs" },
        { "label": "English", "value": "en" }
      ]
    },
    {
      "name": "is_active",
      "type": "boolean",
      "label": "$.text.is_active"
    }
  ]
}
