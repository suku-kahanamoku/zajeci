{
  "syscode": "admin-user-list",
  "restUrl": "/api/admin/user",
  "deleteUrl": "/api/admin/user/${item.id}",
  "factory": {
    "url": "${email}--$${id}"
  },
  "projection": [
    "id",
    "email",
    "name",
    "surname",
    "role",
    "is_active"
  ],
  "fields": [
    {
      "name": "id",
      "label": "$.user.id"
    },
    {
      "name": "email",
      "label": "$.user.email"
    },
    {
      "name": "name",
      "label": "$.user.name"
    },
    {
      "name": "surname",
      "label": "$.user.surname"
    },
    {
      "name": "role",
      "label": "$.user.role"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.is_active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}