{
  "syscode": "admin-user-list",
  "restUrl": "/api/admin/user",
  "deleteUrl": "/api/admin/user/${item.id}",
  "factory": {
    "url": "${email}--$${id}"
  },
  "fields": [
    {
      "name": "email",
      "type": "text",
      "label": "$.user.email"
    },
    {
      "name": "first_name",
      "type": "text",
      "label": "$.user.name"
    },
    {
      "name": "last_name",
      "type": "text",
      "label": "$.user.surname"
    },
    {
      "name": "role",
      "type": "text",
      "label": "$.user.role"
    }
  ]
}