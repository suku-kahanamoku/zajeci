{
  "syscode": "admin-category-list",
  "restUrl": "/api/category",
  "deleteUrl": "/api/admin/category/${item.id}",
  "pagination": {
    "limit": 20
  },
  "factory": {
    "url": "${name}--$${id}"
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.category.name",
      "operator": {
        "value": "$regex",
        "enabled": true
      }
    },
    {
      "name": "syscode",
      "type": "text",
      "label": "$.category.syscode",
      "operator": {
        "value": "$regex",
        "enabled": true
      }
    },
    {
      "name": "position",
      "type": "number",
      "label": "$.category.position"
    }
  ]
}