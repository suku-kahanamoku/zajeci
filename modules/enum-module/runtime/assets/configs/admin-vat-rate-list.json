{
  "syscode": "admin-vat-rate-list",
  "restUrl": "/api/enumerations?q={\"type\":{\"value\":\"vat_rate\"}}",
  "deleteUrl": "/api/admin/enum/${item.id}",
  "sort": [{"created_at": -1}],
  "pagination": {
    "limit": 20
  },
  "fields": [
    {
      "name": "label",
      "type": "text",
      "label": "$.form.name",
      "operator": {
        "value": "$regex",
        "enabled": true
      },
      "size": "md",
      "clearable": true
    },
    {
      "name": "data.rate",
      "type": "number",
      "label": "$.vat_rate.form.rate",
      "size": "md",
      "clearable": true
    },
    {
      "name": "deleted",
      "type": "select",
      "label": "$.form.deleted",
      "options": [
        { "value": 1, "label": "$.form.yes" },
        { "value": 0, "label": "$.form.no" }
      ],
      "size": "md",
      "clearable": true
    }
  ]
}
