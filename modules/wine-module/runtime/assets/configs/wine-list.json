{
  "syscode": "wine-list",
  "restUrl": "/api/wine",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "name",
    "kind",
    "data.quality",
    "color",
    "variant",
    "data.volume",
    "data.year",
    "price",
    "stock_quantity",
    "data.winery",
    "data.region",
    "data.alcohol",
    "data.serving_temp"
  ],
  "fields": [
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_color&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "variant",
      "type": "text",
      "label": "$.wine.form.variant"
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "data.quality",
      "type": "select",
      "label": "$.wine.form.quality",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_quality&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_kind&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume"
    }
  ]
}