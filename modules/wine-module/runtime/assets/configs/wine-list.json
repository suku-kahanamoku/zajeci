{
  "syscode": "wine-list",
  "restUrl": "/api/wine",
  "factory": {
    "url": "${name}--$${id}"
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "placeholder": "$.wine.placeholder.name"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "options": [
        { "value": "dry", "label": "$.wine.kind.dry" },
        { "value": "semiDry", "label": "$.wine.kind.semi_dry" },
        { "value": "sweet", "label": "$.wine.kind.sweet" },
        { "value": "semiSweet", "label": "$.wine.kind.semi_sweet" },
        { "value": "extraDry", "label": "$.wine.kind.extra_dry" },
        { "value": "offDry", "label": "$.wine.kind.off_dry" },
        { "value": "mediumDry", "label": "$.wine.kind.medium_dry" },
        { "value": "mediumSweet", "label": "$.wine.kind.medium_sweet" },
        { "value": "verySweet", "label": "$.wine.kind.very_sweet" },
        { "value": "dessert", "label": "$.wine.kind.dessert" }
      ]
    },
    {
      "name": "quality",
      "type": "select",
      "label": "$.wine.form.quality",
      "placeholder": "$.form.select",
      "options": [
        { "value": "kabinett", "label": "$.wine.quality.kabinett" },
        {
          "value": "late_harvest",
          "label": "$.wine.quality.late_harvest"
        },
        {
          "value": "selection_of_grapes",
          "label": "$.wine.quality.selection_of_grapes"
        },
        {
          "value": "selection_of_berries",
          "label": "$.wine.quality.selection_of_berries"
        },
        { "value": "ice_wine", "label": "$.wine.quality.ice_wine" },
        { "value": "straw_wine", "label": "$.wine.quality.straw_wine" },
        {
          "value": "quality_wine",
          "label": "$.wine.quality.quality_wine"
        },
        {
          "value": "archive_wine",
          "label": "$.wine.quality.archive_wine"
        },
        { "value": "table_wine", "label": "$.wine.quality.table_wine" }
      ]
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "options": [
        { "value": "white", "label": "$.wine.color.white" },
        { "value": "red", "label": "$.wine.color.red" },
        { "value": "rose", "label": "$.wine.color.rose" },
        { "value": "orange", "label": "$.wine.color.orange" }
      ]
    },
    {
      "name": "variant",
      "type": "select",
      "label": "$.wine.form.variety",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "cabernet_sauvignon",
          "label": "$.wine.variant.cabernet_sauvignon"
        },
        { "value": "chardonnay", "label": "$.wine.variant.chardonnay" },
        { "value": "frankovka", "label": "$.wine.variant.frankovka" },
        {
          "value": "gruner_veltliner",
          "label": "$.wine.variant.gruner_veltliner"
        },
        { "value": "merlot", "label": "$.wine.variant.merlot" },
        {
          "value": "modry_portugal",
          "label": "$.wine.variant.modry_portugal"
        },
        {
          "value": "mueller_thurgau",
          "label": "$.wine.variant.mueller_thurgau"
        },
        { "value": "muscat", "label": "$.wine.variant.muscat" },
        { "value": "pinot_blanc", "label": "$.wine.variant.pinot_blanc" },
        { "value": "pinot_gris", "label": "$.wine.variant.pinot_gris" },
        { "value": "pinot_noir", "label": "$.wine.variant.pinot_noir" },
        { "value": "riesling", "label": "$.wine.variant.riesling" },
        {
          "value": "sauvignon_blanc",
          "label": "$.wine.variant.sauvignon_blanc"
        },
        { "value": "st_laurent", "label": "$.wine.variant.st_laurent" },
        { "value": "traminer", "label": "$.wine.variant.traminer" },
        {
          "value": "welschriesling",
          "label": "$.wine.variant.welschriesling"
        },
        { "value": "zweigelt", "label": "$.wine.variant.zweigelt" },
        { "value": "other", "label": "$.wine.variant.other" }
      ]
    },
    {
      "name": "volume",
      "type": "number",
      "label": "$.wine.form.volume"
    },
    {
      "name": "year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    }
  ]
}
