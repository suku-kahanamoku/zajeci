{
  "syscode": "admin-wine-update",
  "restUrl": "/api/wine/${route.meta.id}",
  "patchUrl": "/api/admin/wine/${route.meta.id}",
  "method": "PATCH",
  "modelType": "wine",
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "placeholder": "$.wine.placeholder.name",
      "required": true
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "required": true,
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_kind\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_color\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "variant",
      "type": "select",
      "label": "$.wine.form.variant",
      "placeholder": "$.wine.placeholder.variant",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_variety\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price",
      "required": true
    },
    {
      "name": "vat_rate",
      "type": "number",
      "label": "$.wine.form.vat_rate"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume"
    },
    {
      "name": "data.quality",
      "type": "select",
      "label": "$.wine.form.quality",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_quality\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "data.alcohol",
      "type": "number",
      "label": "$.wine.form.alcohol"
    },
    {
      "name": "data.winery",
      "type": "text",
      "label": "$.wine.form.winery"
    },
    {
      "name": "data.region",
      "type": "text",
      "label": "$.wine.form.region"
    },
    {
      "name": "data.serving_temp",
      "type": "text",
      "label": "$.wine.form.serving_temp"
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "$.form.description"
    },
    {
      "name": "category_ids",
      "type": "select",
      "label": "$.form.categories",
      "placeholder": "$.form.select",
      "multiple": true,
      "restOptions": {
        "url": "/api/categories?q={\"is_active\":{\"value\":1}}&limit=100",
        "label": "name",
        "value": "id"
      }
    }
  ]
}