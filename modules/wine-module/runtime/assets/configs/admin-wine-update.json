{
  "syscode": "admin-wine-update",
  "restUrl": "/api/wine/${route.meta.id}",
  "patchUrl": "/api/admin/wine/${route.meta.id}",
  "method": "PATCH",
  "modelType": "wine",
  "uploadField": {
    "name": "paths",
    "type": "file",
    "multiple": true,
    "required": false,
    "fileSize": 20,
    "fileTypes": [
      {
        "label": "JPG, PNG, GIF, WEBP",
        "value": [
          "image/jpeg",
          "image/png",
          "image/gif",
          "image/webp"
        ]
      }
    ]
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "placeholder": "$.wine.placeholder.name",
      "required": true
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku"
    },
    {
      "name": "data.batch",
      "type": "text",
      "label": "$.wine.form.batch"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "required": true,
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_kind\"},\"published\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_color\"},\"published\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "variant",
      "type": "text",
      "label": "$.wine.form.variant",
      "placeholder": "$.wine.placeholder.variant"
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price",
      "required": true
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "published",
      "type": "select",
      "label": "$.form.published",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume"
    },
    {
      "name": "data.quality",
      "type": "text",
      "label": "$.wine.form.quality"
    },
    {
      "name": "data.alcohol",
      "type": "number",
      "label": "$.wine.form.alcohol"
    },
    {
      "name": "data.winery",
      "type": "text",
      "label": "$.wine.form.winery"
    },
    {
      "name": "data.region",
      "type": "text",
      "label": "$.wine.form.region"
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "$.form.description"
    },
    {
      "name": "category_ids",
      "type": "select",
      "label": "$.form.categories",
      "placeholder": "$.form.select",
      "multiple": true,
      "restOptions": {
        "url": "/api/category?limit=100",
        "label": "name",
        "value": "id"
      }
    }
  ]
}