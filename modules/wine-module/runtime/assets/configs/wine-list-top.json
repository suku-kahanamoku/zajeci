{
  "syscode": "wine-list-top",
  "restUrl": "/api/wine?category_syscode=top",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "name",
    "kind",
    "data.quality",
    "color",
    "variant",
    "data.volume",
    "data.year",
    "price",
    "stock_quantity",
    "data.winery",
    "data.region",
    "data.alcohol",
    "data.serving_temp"
  ],
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "placeholder": "$.wine.placeholder.name"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_kind&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "data.quality",
      "type": "select",
      "label": "$.wine.form.quality",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_quality&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_color&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "variant",
      "type": "select",
      "label": "$.wine.form.variant",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_variety&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume"
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "data.winery",
      "type": "text",
      "label": "$.wine.form.winery"
    },
    {
      "name": "data.region",
      "type": "text",
      "label": "$.wine.form.region"
    },
    {
      "name": "data.alcohol",
      "type": "number",
      "label": "$.wine.form.alcohol"
    },
    {
      "name": "data.serving_temp",
      "type": "text",
      "label": "$.wine.form.serving_temp"
    }
  ]
}