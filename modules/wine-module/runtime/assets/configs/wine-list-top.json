{
  "syscode": "wine-list-top",
  "restUrl": "/api/wine?category_syscode=top",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "name",
    "kind",
    "data.quality",
    "color",
    "variant",
    "data.volume",
    "data.year",
    "price",
    "stock_quantity",
    "data.winery",
    "data.region",
    "data.alcohol",
    "data.serving_temp"
  ],
  "fields": [
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "iconName": "i-heroicons-paint-brush",
      "iconColor": "text-pink-500",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_color&is_active=1&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "variant",
      "type": "text",
      "label": "$.wine.form.variant",
      "iconName": "i-heroicons-sparkles",
      "iconColor": "text-green-500"
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year",
      "iconName": "i-heroicons-calendar",
      "iconColor": "text-amber-500"
    },
    {
      "name": "data.quality",
      "type": "select",
      "label": "$.wine.form.quality",
      "iconName": "i-heroicons-star",
      "iconColor": "text-yellow-500",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_quality&is_active=1&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "iconName": "i-heroicons-tag",
      "iconColor": "text-primary-500",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_kind&is_active=1&limit=100",
        "label": "label",
        "value": "value"
      }
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume",
      "iconName": "i-heroicons-beaker",
      "iconColor": "text-blue-500"
    }
  ]
}