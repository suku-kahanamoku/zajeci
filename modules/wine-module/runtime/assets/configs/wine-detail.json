{
  "syscode": "wine-detail",
  "restUrl": "/api/wine/${route.meta.id}",
  "projection": [
    "name",
    "kind",
    "color",
    "variant",
    "price",
    "stock_quantity",
    "description",
    "data.quality",
    "data.volume",
    "data.year",
    "data.grape",
    "data.sugar",
    "data.alcohol",
    "data.winery",
    "data.region",
    "data.serving_temp"
  ],
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "placeholder": "$.wine.placeholder.name"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "white",
          "label": "$.wine.kind.white"
        },
        {
          "value": "red",
          "label": "$.wine.kind.red"
        },
        {
          "value": "rosé",
          "label": "$.wine.kind.rose"
        },
        {
          "value": "sparkling",
          "label": "$.wine.kind.sparkling"
        },
        {
          "value": "dessert",
          "label": "$.wine.kind.dessert"
        }
      ]
    },
    {
      "name": "data.quality",
      "type": "text",
      "label": "$.wine.form.quality",
      "placeholder": "$.wine.placeholder.quality"
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "yellow",
          "label": "$.wine.color.yellow"
        },
        {
          "value": "white",
          "label": "$.wine.color.white"
        },
        {
          "value": "red",
          "label": "$.wine.color.red"
        },
        {
          "value": "rosé",
          "label": "$.wine.color.rose"
        }
      ]
    },
    {
      "name": "variant",
      "type": "text",
      "label": "$.wine.form.variant"
    },
    {
      "name": "data.volume",
      "type": "number",
      "label": "$.wine.form.volume"
    },
    {
      "name": "data.year",
      "type": "number",
      "label": "$.wine.form.year"
    },
    {
      "name": "data.grape",
      "type": "text",
      "label": "$.wine.form.grape"
    },
    {
      "name": "data.sugar",
      "type": "text",
      "label": "$.wine.form.sugar"
    },
    {
      "name": "data.alcohol",
      "type": "number",
      "label": "$.wine.form.alcohol"
    },
    {
      "name": "data.winery",
      "type": "text",
      "label": "$.wine.form.winery"
    },
    {
      "name": "data.region",
      "type": "text",
      "label": "$.wine.form.region"
    },
    {
      "name": "data.serving_temp",
      "type": "text",
      "label": "$.wine.form.serving_temp"
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "$.form.description"
    }
  ]
}