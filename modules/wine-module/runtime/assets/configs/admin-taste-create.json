{
  "syscode": "admin-taste-create",
  "postUrl": "/api/admin/taste",
  "method": "POST",
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.form.name",
      "placeholder": "$.admin.taste.placeholder.name",
      "required": true
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price",
      "required": true
    },
    {
      "name": "data.drink",
      "type": "text",
      "label": "$.admin.taste.form.drink",
      "placeholder": "$.admin.taste.placeholder.drink"
    },
    {
      "name": "data.food",
      "type": "text",
      "label": "$.admin.taste.form.food",
      "placeholder": "$.admin.taste.placeholder.food"
    },
    {
      "name": "data.time",
      "type": "text",
      "label": "$.admin.taste.form.time",
      "placeholder": "$.admin.taste.placeholder.time"
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "$.form.description"
    },
    {
      "name": "published",
      "type": "select",
      "label": "$.form.published",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}
