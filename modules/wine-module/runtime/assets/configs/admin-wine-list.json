{
  "syscode": "admin-wine-list",
  "restUrl": "/api/admin/wine",
  "deleteUrl": "/api/admin/wine/${item.id}",
  "factory": {
    "url": "${name}--$${id}"
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name"
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_kind&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?type=wine_color&is_active=1&limit=100",
        "label": "label",
        "value": "id"
      }
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ]
    }
  ]
}