{
  "syscode": "admin-wine-list",
  "restUrl": "/api/wine",
  "deleteUrl": "/api/admin/wine/${item.id}",
  "pagination": {
    "limit": 20
  },
  "factory": {
    "url": "${name}--$${id}"
  },
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name",
      "operator": {
        "value": "$regex",
        "enabled": true
      },
      "size": "md"
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku",
      "operator": {
        "value": "$regex",
        "enabled": true
      },
      "size": "md"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_kind\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      },
      "size": "md"
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "restOptions": {
        "url": "/api/enumerations?q={\"type\":{\"value\":\"wine_color\"},\"is_active\":{\"value\":1}}&limit=100",
        "label": "label",
        "value": "value"
      },
      "size": "md"
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price",
      "size": "md"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock",
      "size": "md"
    },
    {
      "name": "is_active",
      "type": "select",
      "label": "$.form.active",
      "options": [
        {
          "value": 1,
          "label": "$.form.yes"
        },
        {
          "value": 0,
          "label": "$.form.no"
        }
      ],
      "size": "md"
    }
  ]
}