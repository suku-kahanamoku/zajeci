{
  "syscode": "admin-wine-list",
  "restUrl": "/api/admin/wine",
  "deleteUrl": "/api/admin/wine/${item.id}",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "name",
    "sku",
    "kind",
    "color",
    "price",
    "stock_quantity",
    "is_active"
  ],
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name"
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "white",
          "label": "$.wine.kind.white"
        },
        {
          "value": "red",
          "label": "$.wine.kind.red"
        },
        {
          "value": "rosé",
          "label": "$.wine.kind.rose"
        },
        {
          "value": "sparkling",
          "label": "$.wine.kind.sparkling"
        },
        {
          "value": "dessert",
          "label": "$.wine.kind.dessert"
        }
      ]
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "yellow",
          "label": "$.wine.color.yellow"
        },
        {
          "value": "white",
          "label": "$.wine.color.white"
        },
        {
          "value": "red",
          "label": "$.wine.color.red"
        },
        {
          "value": "rosé",
          "label": "$.wine.color.rose"
        }
      ]
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "is_active",
      "type": "toggle",
      "label": "$.form.active"
    }
  ]
}