{
  "syscode": "admin-wine-list",
  "restUrl": "/api/admin/wine",
  "deleteUrl": "/api/admin/wine/${item.id}",
  "factory": {
    "url": "${name}--$${id}"
  },
  "projection": [
    "name",
    "sku",
    "kind",
    "color",
    "price",
    "stock_quantity",
    "is_active"
  ],
  "fields": [
    {
      "name": "name",
      "type": "text",
      "label": "$.wine.form.name"
    },
    {
      "name": "sku",
      "type": "text",
      "label": "$.wine.form.sku"
    },
    {
      "name": "kind",
      "type": "select",
      "label": "$.wine.form.kind",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "dry",
          "label": "$.wine.kind.dry"
        },
        {
          "value": "semiDry",
          "label": "$.wine.kind.semi_dry"
        },
        {
          "value": "sweet",
          "label": "$.wine.kind.sweet"
        },
        {
          "value": "semiSweet",
          "label": "$.wine.kind.semi_sweet"
        },
        {
          "value": "extraDry",
          "label": "$.wine.kind.extra_dry"
        },
        {
          "value": "offDry",
          "label": "$.wine.kind.off_dry"
        },
        {
          "value": "mediumDry",
          "label": "$.wine.kind.medium_dry"
        },
        {
          "value": "mediumSweet",
          "label": "$.wine.kind.medium_sweet"
        },
        {
          "value": "verySweet",
          "label": "$.wine.kind.very_sweet"
        },
        {
          "value": "dessert",
          "label": "$.wine.kind.dessert"
        }
      ]
    },
    {
      "name": "color",
      "type": "select",
      "label": "$.wine.form.color",
      "placeholder": "$.form.select",
      "options": [
        {
          "value": "white",
          "label": "$.wine.color.white"
        },
        {
          "value": "red",
          "label": "$.wine.color.red"
        },
        {
          "value": "rose",
          "label": "$.wine.color.rose"
        }
      ]
    },
    {
      "name": "price",
      "type": "number",
      "label": "$.form.price"
    },
    {
      "name": "stock_quantity",
      "type": "number",
      "label": "$.form.quantity_stock"
    },
    {
      "name": "is_active",
      "type": "toggle",
      "label": "$.form.active"
    }
  ]
}