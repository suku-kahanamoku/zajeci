{
  "syscode": "admin-invoice-list",
  "restUrl": "/api/admin/invoice",
  "deleteUrl": "/api/admin/invoice/${item.id}",
  "pagination": {
    "limit": 20
  },
  "factory": {
    "url": "${invoice_number}--$${id}"
  },
  "fields": [
    {
      "name": "invoice_number",
      "label": "$.invoice.invoice_number",
      "size": "md",
      "clearable": true
    },
    {
      "name": "status",
      "type": "select",
      "label": "$.invoice.status",
      "options": [
        { "label": "$.invoice.status_draft", "value": "draft" },
        { "label": "$.invoice.status_issued", "value": "issued" },
        { "label": "$.invoice.status_paid", "value": "paid" },
        { "label": "$.invoice.status_overdue", "value": "overdue" },
        { "label": "$.invoice.status_cancelled", "value": "cancelled" },
        { "label": "$.invoice.status_refunded", "value": "refunded" }
      ],
      "operator": {
        "value": "$eq",
        "enabled": true
      },
      "size": "md",
      "clearable": true
    },
    {
      "name": "total_amount",
      "type": "number",
      "label": "$.invoice.total_amount",
      "size": "md",
      "clearable": true
    },
    {
      "name": "due_date",
      "type": "text",
      "label": "$.invoice.due_date",
      "size": "md",
      "clearable": true
    }
  ]
}