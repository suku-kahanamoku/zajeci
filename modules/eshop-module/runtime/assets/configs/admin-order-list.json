{
  "syscode": "admin-order-list",
  "restUrl": "/api/admin/order",
  "deleteUrl": "/api/admin/order/${item.id}",
  "pagination": {
    "limit": 20
  },
  "factory": {
    "url": "${order_number}--$${id}"
  },
  "fields": [
    {
      "name": "order_number",
      "label": "$.order.order_number",
      "size": "md"
    },
    {
      "name": "status",
      "label": "$.order.status",
      "size": "md"
    },
    {
      "name": "payment_method",
      "label": "$.order.payment_type",
      "size": "md"
    },
    {
      "name": "total_amount",
      "type": "number",
      "label": "$.order.total_price",
      "size": "md"
    }
  ]
}