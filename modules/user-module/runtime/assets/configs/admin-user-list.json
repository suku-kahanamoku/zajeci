{
  "syscode": "admin-user-list",
  "restUrl": "/api/admin/user",
  "deleteUrl": "/api/admin/user/${item.id}",
  "pagination": { "limit": 20 },
  "factory": {
    "url": "${email}--$${id}"
  },
  "fields": [
    {
      "name": "email",
      "type": "text",
      "label": "$.user.email",
      "operator": { "value": "$regex", "enabled": true }
    },
    {
      "name": "first_name",
      "type": "text",
      "label": "$.user.name",
      "operator": { "value": "$regex", "enabled": true }
    },
    {
      "name": "last_name",
      "type": "text",
      "label": "$.user.surname",
      "operator": { "value": "$regex", "enabled": true }
    },
    {
      "name": "role",
      "type": "text",
      "label": "$.user.role",
      "operator": { "value": "$regex", "enabled": true }
    }
  ]
}
